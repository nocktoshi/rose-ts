{
  "name": "@nockchain/rose-ts",
  "version": "0.2.2",
  "description": "Pure TypeScript Wallet Primitives for Nockchain",
  "author": "Nocktoshi <nocktoshi@nockchain.net>",
  "license": "GPL-3.0",
  "rereadmeFile": "README.md",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nocktoshi/rose-ts.git"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./internal": {
      "types": "./dist/internal.d.ts",
      "import": "./dist/internal.js"
    }
  },
  "scripts": {
    "prebuild": "node scripts/proto-gen.mjs && eslint",
    "build": "tsc --sourceMap",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint",
    "lint:fix": "eslint --fix"
  },
  "dependencies": {
    "@bufbuild/protobuf": "2.12.0",
    "@noble/hashes": "2.2.0",
    "@scure/base": "2.2.0",
    "@scure/bip39": "2.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nockchain/rose-wasm": "0.2.0-alpha.4",
    "@types/node": "25.9.3",
    "eslint": "^10.5.0",
    "eslint-plugin-prefer-arrow-functions": "^3.9.1",
    "gts": "^7.0.0",
    "ts-proto": "^2.11.8",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0",
    "vitest": "4.1.9"
  }
}
